.released-products-screen {
    flex-grow: 1;
    flex-direction: column;
}

.crisis-badge {
    background-color: rgb(180, 40, 40);
    border-radius: 3px;
    padding: 1px 5px;
    color: rgb(255, 255, 255);
    font-size: 10px;
}

.lifecycle-launch { color: rgb(80, 200, 120); }
.lifecycle-growth { color: rgb(100, 180, 220); }
.lifecycle-plateau { color: rgb(200, 200, 80); }
.lifecycle-decline { color: rgb(220, 120, 60); }
