%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 068ed6961b9bb174b92b7f95d62a44e2, type: 3}
  m_Name: TooltipRegistry
  m_EditorClassIdentifier: Assembly-CSharp::TooltipRegistry
  _entries:
  - Key: topbar.balance
    Data:
      Title: Balance
      Body: Your current cash on hand. Used for salaries, purchases, and operational
        costs.
      Stats: []
  - Key: topbar.net-income
    Data:
      Title: Net Income
      Body: Monthly revenue minus monthly expenses. Positive means profit.
      Stats: []
  - Key: topbar.date
    Data:
      Title: Date
      Body: Current in-game date. Time advances when you press Continue.
      Stats: []
  - Key: topbar.reputation
    Data:
      Title: Reputation
      Body: Your company's standing. Earned by completing contracts successfully.
      Stats: []
  - Key: employee.salary
    Data:
      Title: Salary
      Body: Monthly payment to this employee. Paid automatically on the 1st.
      Stats: []
  - Key: employee.morale
    Data:
      Title: Morale
      Body: Affects work speed and quality. Improves with rest, drops from overwork.
      Stats: []
  - Key: employee.skill
    Data:
      Title: Skill Level
      Body: Proficiency in this discipline. Higher skill means faster, higher quality
        work.
      Stats: []
  - Key: contract.deadline
    Data:
      Title: Deadline
      Body: Days remaining to deliver. Missing a deadline damages reputation.
      Stats: []
  - Key: contract.reward
    Data:
      Title: Reward
      Body: Payment received on successful completion.
      Stats: []
  - Key: contract.difficulty
    Data:
      Title: Difficulty
      Body: Higher difficulty requires more skilled employees and more time.
      Stats: []
  - Key: market.demand
    Data:
      Title: Market Demand
      Body: Current demand for this niche. Higher demand means easier sales.
      Stats: []
  - Key: market.trend
    Data:
      Title: Trend
      Body: Direction demand is moving. Rising trends signal good investment opportunities.
      Stats: []
  - Key: research.cost
    Data:
      Title: Research Time
      Body: Days to complete this research.
      Stats: []
  - Key: research.queue
    Data:
      Title: Research Queue
      Body: Queued research starts automatically when the current project finishes.
      Stats: []
  - Key: team.assignment
    Data:
      Title: Team Assignment
      Body: The contract this team is currently working on.
      Stats: []
  - Key: finance.expenses
    Data:
      Title: Monthly Expenses
      Body: Total recurring costs including salaries, rent, and maintenance.
      Stats: []
  - Key: finance.revenue
    Data:
      Title: Monthly Revenue
      Body: Total income from completed contracts and products.
      Stats: []
